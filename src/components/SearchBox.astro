<div class="search-container">
  <input
    id="search-input"
    type="text"
    placeholder="输入关键词搜索文章..."
    autocomplete="off"
    aria-label="搜索文章"
    class="w-full px-4 py-3 rounded-lg bg-bg-secondary border border-border text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-accent transition-colors"
  />
  <ul id="search-results" class="mt-4 space-y-4"></ul>
  <p id="search-status" class="mt-4 text-text-secondary text-sm hidden" aria-live="polite" role="status"></p>
</div>

<script>
  import Fuse from 'fuse.js';
  import type { SearchEntry } from '../utils/search';

  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('search-results') as HTMLUListElement;
  const statusEl = document.getElementById('search-status') as HTMLParagraphElement;

  async function initSearch() {
    try {
      const baseUrl = import.meta.env.BASE_URL ?? '/';
      const res = await fetch(`${baseUrl}search.json`);
      if (!res.ok) throw new Error('Failed to load search index');
      const posts: SearchEntry[] = await res.json();

      const fuse = new Fuse(posts, {
        keys: ['title', 'description', 'content', 'tags'],
        threshold: 0.3,
      });

      let debounceTimer: ReturnType<typeof setTimeout>;

      input.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          const query = input.value.trim();
          statusEl.classList.add('hidden');

          if (!query) {
            resultsEl.innerHTML = '';
            return;
          }

          const results = fuse.search(query);
          if (results.length === 0) {
            resultsEl.innerHTML = '';
            statusEl.textContent = `没有找到与 "${query}" 相关的文章。`;
            statusEl.classList.remove('hidden');
            return;
          }

          resultsEl.innerHTML = '';
          results.forEach(result => {
            const li = document.createElement('li');
            li.className = 'border-b border-border pb-4 last:border-0';

            const a = document.createElement('a');
            a.href = `${baseUrl}blog/${result.item.slug}/`;
            a.className = 'text-lg font-display font-bold text-text-primary hover:text-accent transition-colors';
            a.textContent = result.item.title;

            const p = document.createElement('p');
            p.className = 'text-text-secondary mt-1 line-clamp-2';
            p.textContent = result.item.description;

            const tagsDiv = document.createElement('div');
            tagsDiv.className = 'flex flex-wrap gap-2 mt-2';
            result.item.tags.forEach(tag => {
              const span = document.createElement('span');
              span.className = 'text-xs text-text-secondary';
              span.textContent = `#${tag}`;
              tagsDiv.appendChild(span);
            });

            li.appendChild(a);
            li.appendChild(p);
            li.appendChild(tagsDiv);
            resultsEl.appendChild(li);
          });
        }, 200);
      });
    } catch (error) {
      console.error('Search initialization failed:', error);
      statusEl.textContent = '搜索暂不可用，请直接浏览文章列表。';
      statusEl.classList.remove('hidden');
      input.disabled = true;
    }
  }

  initSearch();
</script>
