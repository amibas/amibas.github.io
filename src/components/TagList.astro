---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {tags.map(tag => (
    <a
      href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}
      class="px-5 py-2 rounded-full bg-bg-secondary border-[2px] border-white/40 dark:border-white/10 shadow-clay text-sm font-medium text-text-secondary hover:bg-accent hover:text-white hover:border-accent/30 hover:shadow-clay-hover hover:-translate-y-0.5 active:scale-95 transition-all duration-200 ease-clay focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary"
    >
      #{tag}
    </a>
  ))}
</div>
