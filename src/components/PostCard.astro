---
import { formatDate } from '../utils/posts';
import type { Post } from '../utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<article class="group bg-bg-secondary rounded-3xl p-6 md:p-8 border-[3px] border-white/50 dark:border-white/10 shadow-clay hover:shadow-clay-hover transition-all duration-300 ease-clay hover:-translate-y-1 hover:scale-[1.02] active:scale-[0.98] h-full relative">
  <h3 class="text-lg md:text-xl font-semibold tracking-wide text-text-primary mb-2">
    <a
      href={`${import.meta.env.BASE_URL}blog/${post.id}/`}
      class="no-underline before:absolute before:inset-0 focus:outline-none focus:ring-2 focus:ring-accent rounded-3xl"
    >
      {title}
    </a>
  </h3>
  <p class="text-text-secondary leading-relaxed line-clamp-2">{description}</p>
  <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-text-secondary">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    <span aria-hidden="true">&middot;</span>
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="px-2.5 py-1 rounded-full bg-bg-primary/50 border border-white/30 dark:border-white/10 text-xs font-medium">#{tag}</span>
      ))}
    </div>
  </div>
</article>
