---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostGrid from '../components/PostGrid.astro';
import TagList from '../components/TagList.astro';
import AmoebaBlob from '../components/AmoebaBlob.astro';
import { getAllPosts, getAllTags } from '../utils/posts';

const posts = await getAllPosts();
const recentPosts = posts.slice(0, 5);
const tags = getAllTags(posts);
---

<BaseLayout title="amoeba的博客 - 技术笔记与教程" description="一个记录技术笔记与教程的个人博客">
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-16 md:pt-24 md:pb-20">
    <div class="mb-16 md:mb-20 relative flex flex-col md:flex-row items-center gap-10 md:gap-6">
      <div class="absolute -top-10 -left-10 w-48 h-48 rounded-full bg-accent/10 blur-3xl animate-blob pointer-events-none" aria-hidden="true"></div>
      <div class="absolute top-20 -right-5 w-36 h-36 rounded-full bg-accent-secondary/10 blur-3xl animate-blob pointer-events-none" style="animation-delay: -4s;" aria-hidden="true"></div>

      <div class="relative z-10 flex-1">
        <p class="text-sm font-medium text-accent mb-3 animate-fade-in-up">欢迎来到 amoeba 的博客</p>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-semibold tracking-wide text-text-primary mb-4 animate-fade-in-up stagger-1">
          技术笔记与教程
        </h1>
        <p class="text-lg md:text-xl text-text-secondary leading-relaxed max-w-xl animate-fade-in-up stagger-2">
          记录学习、实践和思考。主要关注前端工程、开发工具和技术写作。
        </p>
      </div>

      <div class="relative z-10 hidden md:flex items-center justify-center flex-1">
        <div class="relative">
          <AmoebaBlob size={14} />
          <span class="absolute -top-4 -right-4 w-6 h-6 rounded-full bg-[#F4A4C0]/40 blur-sm animate-blob" style="animation-delay: -1s;" aria-hidden="true"></span>
          <span class="absolute top-1/2 -right-8 w-4 h-4 rounded-full bg-[#C4B5FD]/50 blur-sm animate-blob" style="animation-delay: -3s;" aria-hidden="true"></span>
          <span class="absolute -bottom-2 left-0 w-5 h-5 rounded-full bg-[#A7F3D0]/50 blur-sm animate-blob" style="animation-delay: -5s;" aria-hidden="true"></span>
        </div>
      </div>
    </div>

    <div class="mb-16 animate-fade-in-up stagger-3">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
          <h2 class="text-xl font-semibold tracking-wide text-text-primary">最近文章</h2>
        </div>
        <a href={`${import.meta.env.BASE_URL}blog`} class="text-sm font-medium">查看全部 &rarr;</a>
      </div>
      {recentPosts.length > 0 ? (
        <PostGrid posts={recentPosts} baseDelay={0.3} stagger={0.08} />
      ) : (
        <p class="text-text-secondary">还没有文章，快去写一篇吧。</p>
      )}
    </div>

    <div class="mt-16 animate-fade-in-up stagger-5">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-secondary" aria-hidden="true"></span>
        <h2 class="text-xl font-semibold tracking-wide text-text-primary">标签</h2>
      </div>
      {tags.length > 0 ? <TagList tags={tags} /> : <p class="text-text-secondary">暂无标签</p>}
    </div>
  </section>
</BaseLayout>
