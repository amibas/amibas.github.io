---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagList from '../../components/TagList.astro';
import { getAllPosts, getAllTags } from '../../utils/posts';

const posts = await getAllPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="全部文章 - 我的博客" description="博客全部文章列表">
  <section class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-text-primary mb-8">全部文章</h1>

    <div class="mb-10">
      <h2 class="text-xs font-medium text-text-secondary uppercase tracking-wide mb-4">按标签筛选</h2>
      <TagList tags={tags} />
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {posts.map(post => <PostCard post={post} />)}
      </div>
    ) : (
      <p class="text-text-secondary">还没有文章。</p>
    )}
  </section>
</BaseLayout>
