---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostGrid from '../../components/PostGrid.astro';
import TagList from '../../components/TagList.astro';
import { getAllPosts, getAllTags } from '../../utils/posts';

const posts = await getAllPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="全部文章 - amoeba的博客" description="博客全部文章列表">
  <section class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <div class="flex items-center gap-3 mb-8 animate-fade-in-up">
      <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
      <h1 class="text-2xl md:text-3xl font-semibold tracking-wide text-text-primary">全部文章</h1>
    </div>

    <div class="mb-10 animate-fade-in-up stagger-1">
      <h2 class="text-xs font-medium text-text-secondary uppercase tracking-wide mb-4">按标签筛选</h2>
      <TagList tags={tags} />
    </div>

    {posts.length > 0 ? (
      <PostGrid posts={posts} />
    ) : (
      <p class="text-text-secondary">还没有文章。</p>
    )}
  </section>
</BaseLayout>
