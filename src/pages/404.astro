---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmoebaBlob from '../components/AmoebaBlob.astro';
---

<BaseLayout title="404 - 页面未找到" description="页面不存在" noindex>
  <section class="max-w-5xl mx-auto px-6 py-24 md:py-32 text-center relative">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-accent/5 blur-3xl animate-blob pointer-events-none" aria-hidden="true"></div>

    <h1 class="relative text-7xl md:text-9xl font-extrabold tracking-tighter bg-gradient-to-b from-accent to-accent-secondary bg-clip-text text-transparent mb-4 animate-fade-in-scale">
      404
    </h1>

    <div class="relative flex justify-center mb-6 animate-fade-in-scale stagger-1">
      <AmoebaBlob variant="sad" size={12} />
    </div>

    <p class="relative text-lg md:text-xl text-text-secondary mb-10 animate-fade-in-up stagger-2">
      这个页面不存在，可能已经被移动或删除。
    </p>
    <div class="relative flex flex-wrap items-center justify-center gap-4 animate-fade-in-up stagger-3">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-block px-8 py-3 rounded-full bg-accent text-white text-sm font-medium border-[3px] border-white/30 dark:border-white/10 shadow-clay hover:shadow-clay-hover hover:-translate-y-1 hover:scale-105 active:scale-95 transition-all duration-300 ease-clay focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary"
      >
        返回首页
      </a>
      <a
        href={`${import.meta.env.BASE_URL}search/`}
        class="inline-block px-8 py-3 rounded-full bg-bg-secondary text-text-primary text-sm font-medium border-[3px] border-white/50 dark:border-white/10 shadow-clay hover:shadow-clay-hover hover:-translate-y-1 hover:scale-105 active:scale-95 transition-all duration-300 ease-clay focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary"
      >
        搜索文章
      </a>
      <a
        href={`${import.meta.env.BASE_URL}tags/`}
        class="inline-block px-8 py-3 rounded-full bg-bg-secondary text-text-primary text-sm font-medium border-[3px] border-white/50 dark:border-white/10 shadow-clay hover:shadow-clay-hover hover:-translate-y-1 hover:scale-105 active:scale-95 transition-all duration-300 ease-clay focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary"
      >
        浏览标签
      </a>
    </div>
  </section>
</BaseLayout>
