---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import PostGrid from '../components/PostGrid.astro';
import TagList from '../components/TagList.astro';
import { getAllPosts, getAllTags } from '../utils/posts';

const posts = await getAllPosts();
const tags = getAllTags(posts);
const recentPosts = posts.slice(0, 4);
---

<BaseLayout title="搜索 - amoeba的博客" description="搜索博客文章">
  <section class="max-w-4xl mx-auto px-6 py-16 md:py-20">
    <div class="flex items-center gap-3 mb-8 animate-fade-in-up">
      <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
      <h1 class="text-2xl md:text-3xl font-semibold tracking-wide text-text-primary">搜索文章</h1>
    </div>
    <div class="animate-fade-in-up stagger-1">
      <SearchBox />
    </div>

    <div class="mt-16 animate-fade-in-up stagger-2">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-secondary" aria-hidden="true"></span>
        <h2 class="text-xl font-semibold tracking-wide text-text-primary">热门标签</h2>
      </div>
      {tags.length > 0 ? <TagList tags={tags} /> : <p class="text-text-secondary">暂无标签</p>}
    </div>

    {recentPosts.length > 0 && (
      <div class="mt-16 animate-fade-in-up stagger-3">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
            <h2 class="text-xl font-semibold tracking-wide text-text-primary">最近文章</h2>
          </div>
          <a href={`${import.meta.env.BASE_URL}blog/`} class="text-sm font-medium">查看全部 &rarr;</a>
        </div>
        <PostGrid posts={recentPosts} />
      </div>
    )}
  </section>
</BaseLayout>
