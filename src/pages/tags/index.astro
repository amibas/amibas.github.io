---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagList from '../../components/TagList.astro';
import { getAllPosts, getAllTags } from '../../utils/posts';

const posts = await getAllPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="全部标签 - 我的博客" description="博客全部标签">
  <section class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-text-primary mb-8">全部标签</h1>
    <TagList tags={tags} />
  </section>
</BaseLayout>
