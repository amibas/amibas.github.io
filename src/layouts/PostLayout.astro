---
import BaseLayout from './BaseLayout.astro';
import { formatDate, getReadingTime } from '../utils/posts';
import type { Post } from '../utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const readingTime = getReadingTime(post.body);
const postURL = new URL(Astro.url.pathname, Astro.site);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'amibas',
  },
  keywords: tags.join(', '),
  url: postURL,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postURL,
  },
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <article class="max-w-4xl mx-auto px-6 py-16 md:py-20">
    <header class="mb-12 p-6 md:p-8 rounded-3xl bg-bg-secondary border-[3px] border-white/50 dark:border-white/10 shadow-clay animate-fade-in-scale">
      <h1 class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-wide leading-snug text-text-primary mb-4 text-balance">
        {title}
      </h1>
      <p class="text-lg text-text-secondary leading-relaxed">{description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-text-secondary">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime} 分钟阅读</span>
        <span aria-hidden="true">&middot;</span>
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <a
              href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}
              class="px-4 py-1.5 rounded-full bg-bg-primary/50 border border-white/30 dark:border-white/10 text-xs font-medium text-text-secondary hover:bg-accent hover:text-white hover:border-accent/30 transition-all duration-200 ease-clay focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-secondary"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </header>

    <div class="prose max-w-none animate-fade-in-up stagger-2">
      <slot />
    </div>
  </article>
</BaseLayout>
