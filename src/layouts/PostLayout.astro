---
import BaseLayout from './BaseLayout.astro';
import { formatDate, getReadingTime } from '../utils/posts';
import type { Post } from '../utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const readingTime = getReadingTime(post.body);
---

<BaseLayout title={title} description={description}>
  <article class="max-w-4xl mx-auto px-6 py-16 md:py-20">
    <header class="mb-12">
      <h1 class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-tight leading-tight text-text-primary mb-4 text-balance">
        {title}
      </h1>
      <p class="text-lg text-text-secondary leading-relaxed">{description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-text-secondary">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span>&middot;</span>
        <span>{readingTime} 分钟阅读</span>
        <span>&middot;</span>
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <a
              href={`${import.meta.env.BASE_URL}tags/${tag}/`}
              class="px-3 py-1 rounded-full bg-bg-secondary text-xs font-medium text-text-secondary hover:bg-accent hover:text-white transition-colors duration-200"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
