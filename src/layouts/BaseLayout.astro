---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const { title, description = '技术笔记与教程', image, noindex = false } = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const ogImageURL = image && Astro.site ? new URL(image, Astro.site) : undefined;
const isArticle = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog/';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href={`${import.meta.env.BASE_URL}rss.xml`} />
    <link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:locale" content="zh_CN" />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Nunito:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:inline>
      :root {
        --bg-primary: 252 252 253;
        --bg-secondary: 247 248 250;
        --text-primary: 31 29 40;
        --text-secondary: 100 100 115;
        --accent: 14 165 233;
        --accent-secondary: 251 146 60;
        --border: 235 235 240;
      }
      :root.dark {
        --bg-primary: 15 23 42;
        --bg-secondary: 30 41 59;
        --text-primary: 248 250 252;
        --text-secondary: 148 163 184;
        --accent: 56 189 248;
        --accent-secondary: 251 146 60;
        --border: 51 65 85;
      }
    </style>
    <script is:inline>
      (function () {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:rounded-xl focus:bg-accent focus:text-white focus:font-medium focus:shadow-lg"
    >
      跳转到主要内容
    </a>
    <header class="sticky top-0 z-50 bg-bg-primary/80 backdrop-blur-xl shadow-sm border-b-[3px] border-white/50 dark:border-white/10">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={`${import.meta.env.BASE_URL}`} class="text-lg font-semibold tracking-wide text-text-primary hover:text-text-secondary transition-colors">
          我的博客
        </a>        <div class="flex items-center gap-6 md:gap-8">
          <a href={`${import.meta.env.BASE_URL}blog/`} class="text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-accent/10 rounded-xl px-3 py-1.5 transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary">
            文章
          </a>
          <a href={`${import.meta.env.BASE_URL}tags/`} class="text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-accent/10 rounded-xl px-3 py-1.5 transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary">
            标签
          </a>
          <a href={`${import.meta.env.BASE_URL}search/`} class="text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-accent/10 rounded-xl px-3 py-1.5 transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary">
            搜索
          </a>
          <a href={`${import.meta.env.BASE_URL}about/`} class="text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-accent/10 rounded-xl px-3 py-1.5 transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary">
            关于
          </a>
          <ThemeToggle />
        </div>
      </nav>
    </header>

    <main id="main-content" tabindex="-1" class="flex-1 w-full outline-none">
      <slot />
    </main>

    <footer class="bg-bg-secondary py-12 mt-16 border-t-[3px] border-white/40 dark:border-white/10 relative overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 text-center text-text-secondary text-sm relative z-10">
        <div class="flex flex-col items-center gap-3">
          <div class="flex items-center gap-4 text-xs">
            <a href={`${import.meta.env.BASE_URL}rss.xml`} class="hover:text-accent transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-secondary rounded">RSS</a>
            <span class="text-border" aria-hidden="true">·</span>
            <a href={`${import.meta.env.BASE_URL}search/`} class="hover:text-accent transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-secondary rounded">搜索</a>
            <span class="text-border" aria-hidden="true">·</span>
            <a href={`${import.meta.env.BASE_URL}about/`} class="hover:text-accent transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-secondary rounded">关于</a>
          </div>
          <p>&copy; <span id="copyright-year">{new Date().getFullYear()}</span> 我的博客. All rights reserved.</p>
        </div>
      </div>
      <div class="absolute -bottom-20 -right-20 w-40 h-40 rounded-full bg-accent/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
    </footer>
    <script is:inline>
      (function () {
        const el = document.getElementById('copyright-year');
        if (el) el.textContent = new Date().getFullYear().toString();
      })();
    </script>
  </body>
</html>
